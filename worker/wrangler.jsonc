{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cosmoscope-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "vars": {
    "AI_READING_PROVIDER": "mock",
    "APP_ENV": "production",
    "APP_URL": "https://cosmo.greenhenncollective.com",
    "CORS_ALLOWED_ORIGINS": "https://cosmoscope.pages.dev",
    "ENABLE_AI_READINGS": "false",
    "ENABLE_PAID_AI_SMOKE": "false",
    "PAYMENTS_DISABLED_PREVIEW": "false",
    "READING_ENGINE_VERSION": "v1",
    "SUPABASE_URL": "https://yjfnorcmbqciysacgyar.supabase.co"
  }
}
